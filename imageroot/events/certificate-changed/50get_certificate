#!/usr/bin/env python3

import json
import os
import sys

import agent


event = json.load(sys.stdin)
certificate_host = (os.getenv("TRAEFIK_HOST") or "").strip().lower()

if not certificate_host:
    sys.exit(0)

if not agent.certificate_event_matches(event, certificate_host):
    sys.exit(0)

sync_proc = agent.run_helper(
    "systemctl",
    "--user",
    "start",
    "teaspeak-certificate.service",
)

if sync_proc.returncode == 0:
    agent.run_helper("systemctl", "--user", "try-restart", "teaspeak.service")