import json
import os
from pathlib import Path
import sys

import agent

request = json.load(sys.stdin)


def parse_bool(value, default):
    if value is None:
        return default
    if isinstance(value, bool):
        return value
    return str(value).strip().lower() in {"1", "true", "yes", "on"}


timezone = (request.get("timezone") or "UTC").strip() or "UTC"
license_key = (request.get("license_key") or "").strip() or "none"
query_ssl_mode = int(request.get("query_ssl_mode", 2))
web_enabled = 1 if parse_bool(request.get("web_enabled"), True) else 0
web_host = (request.get("web_host") or "").strip().lower()
web_lets_encrypt = parse_bool(request.get("web_lets_encrypt"), False)
music_enabled = 1 if parse_bool(request.get("music_enabled"), False) else 0
vpn_check_enabled = 1 if parse_bool(request.get("vpn_check_enabled"), False) else 0

agent.assert_exp(query_ssl_mode in (0, 1, 2), "query_ssl_mode must be 0, 1 or 2")

public_ports = ["9987/udp", "9987/tcp", "10101/tcp", "30303/tcp"]

agent.set_env("TIMEZONE", timezone)
agent.set_env("LICENSE_KEY", license_key)
agent.set_env("QUERY_SSL_MODE", str(query_ssl_mode))
agent.set_env("WEB_ENABLED", str(web_enabled))
agent.set_env("TRAEFIK_HOST", web_host if web_enabled else "")
agent.set_env("TRAEFIK_HTTP2HTTPS", True)
agent.set_env("TRAEFIK_LETS_ENCRYPT", web_lets_encrypt if web_enabled and web_host else False)
agent.set_env("MUSIC_ENABLED", str(music_enabled))
agent.set_env("VPN_CHECK_ENABLED", str(vpn_check_enabled))

state_dir = Path(os.environ["AGENT_STATE_DIR"])
config_dir = state_dir / "config"
config_dir.mkdir(parents=True, exist_ok=True)
runtime_dir = state_dir / "runtime"
runtime_dir.mkdir(parents=True, exist_ok=True)
config_file = config_dir / "config.yml"

config_lines = [
    "general:",
    f"  license: {json.dumps(license_key)}",
    "  database:",
    '    url: "sqlite:///ts/database/TeaData.sqlite"',
    "binding:",
    "  query:",
    '    host: "0.0.0.0"',
    "    port: 10101",
    "  file:",
    '    host: "0.0.0.0"',
    "    port: 30303",
    "query:",
    f"  enableSSL: {query_ssl_mode}",
    "  ssl:",
    '    certificate: "/ts/certs/query_certificate.pem"',
    '    privatekey: "/ts/certs/query_privatekey.pem"',
    "voice:",
    "  default_port: 9987",
    "  suppress_myts_warnings: 1",
    "web:",
    f"  enabled: {web_enabled}",
    "  ssl:",
    '    certificate: "/ts/certs/default_certificate.pem"',
    '    privatekey: "/ts/certs/default_privatekey.pem"',
    "music:",
    f"  enabled: {music_enabled}",
    "vpn:",
    f"  enabled: {vpn_check_enabled}",
]

with open(str(config_file) + ".tmp", "w", encoding="utf-8", newline="\n") as stream:
    stream.write("\n".join(config_lines) + "\n")

os.replace(str(config_file) + ".tmp", config_file)

agent.assert_exp(
    agent.add_public_service(
        os.environ["MODULE_ID"],
        public_ports,
        replace_ports=True,
    ),
    "Firewall service configuration has failed",
)
