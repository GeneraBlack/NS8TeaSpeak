[Unit]
Description=Fetch TeaSpeak TLS certificate from Traefik

[Service]
Type=oneshot
SuccessExitStatus=3
EnvironmentFile=%S/state/environment
WorkingDirectory=%S/state
ExecStart=/bin/sh -ec 'mkdir -p runtime/tls; if [ -z "$TRAEFIK_HOST" ]; then rm -f runtime/tls/default_certificate.pem runtime/tls/default_privatekey.pem; exit 0; fi; exec runagent get-certificate --cert-file=runtime/tls/default_certificate.pem --key-file=runtime/tls/default_privatekey.pem "$TRAEFIK_HOST"'
