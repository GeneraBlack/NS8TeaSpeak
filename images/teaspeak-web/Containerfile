FROM nginx:1.30.1-alpine3.23-slim

ARG TEAWEB_VERSION=59737567

COPY default.conf /etc/nginx/conf.d/default.conf
COPY nginx.conf /etc/nginx/nginx.conf

RUN apk update --no-cache \
    && apk upgrade --no-cache \
    && apk add --no-cache \
        python3 \
        unzip \
    && mkdir -p /var/www/TeaWeb \
    && wget -q -O /var/www/TeaWeb/TeaWeb-release.zip "https://github.com/TeaSpeak/TeaWeb/releases/download/${TEAWEB_VERSION}/TeaWeb-release-${TEAWEB_VERSION}.zip" \
    && unzip -oq /var/www/TeaWeb/TeaWeb-release.zip -d /var/www/TeaWeb

RUN python3 - <<'PY'
from pathlib import Path

index_path = Path("/var/www/TeaWeb/index.html")
index_html = index_path.read_text(encoding="utf-8")
auto_connect_marker = "ns8TeaSpeakAutoConnect"
auto_connect_script = (
    '<script>/* ns8TeaSpeakAutoConnect */(function(){'
    'var url=new URL(window.location.href);'
    'if(url.search.length!==0||url.searchParams.has("connect_default")||'
    'url.searchParams.has("connect_address"))return;'
    'url.searchParams.set("connect_default","1");'
    'url.searchParams.set("connect_address",window.location.hostname);'
    'window.location.replace(url.toString());'
    '})();</script>'
)

if auto_connect_marker not in index_html:
    injection_point = '<meta http-equiv="X-UA-Compatible"content="IE=edge,chrome=1">'
    if injection_point not in index_html:
        raise SystemExit("missing TeaWeb index injection point")
    index_html = index_html.replace(injection_point, injection_point + auto_connect_script, 1)
    index_path.write_text(index_html, encoding="utf-8")

format_bundle_path = Path("/var/www/TeaWeb/js/fe0f4941c6e0916d1f9a.js")
format_bundle_js = format_bundle_path.read_text(encoding="utf-8")
old_snippet = ':"object"===(0,o.default)(e)?e instanceof $?[e]:b("<unknwon object>"):"function"==typeof e?'
new_snippet = ':"object"===(0,o.default)(e)?e instanceof $?[e]:e&&e.nodeType?[$(e)]:b("<unknwon object>"):"function"==typeof e?'
if old_snippet not in format_bundle_js:
    raise SystemExit("missing TeaWeb formatMessage patch target")
format_bundle_js = format_bundle_js.replace(old_snippet, new_snippet, 1)
format_bundle_path.write_text(format_bundle_js, encoding="utf-8")

connection_bundle_path = Path("/var/www/TeaWeb/js/14640fc9f0bf331a50cf.js")
connection_bundle_js = connection_bundle_path.read_text(encoding="utf-8")
cert_address_old_snippet = 'connect_address:this.serverConnection.remote_address().host+(9987!==this.serverConnection.remote_address().port?":"+this.serverConnection.remote_address().port:"")'
cert_address_new_snippet = 'connect_address:(new URLSearchParams(document.location.search).get("connect_address")||this.serverConnection.remote_address().host)+(9987!==this.serverConnection.remote_address().port?":"+this.serverConnection.remote_address().port:"")'
if cert_address_old_snippet not in connection_bundle_js:
    raise SystemExit("missing TeaWeb certificate callback address patch target")
connection_bundle_js = connection_bundle_js.replace(cert_address_old_snippet, cert_address_new_snippet, 1)

cert_url_old_snippet = '"https://"+e.serverConnection.remote_address().host+":"+e.serverConnection.remote_address().port+"/?forward_url="+encodeURIComponent(c)'
cert_url_new_snippet = '"https://"+((new URLSearchParams(document.location.search).get("connect_address")||e.serverConnection.remote_address().host).replace(/:\\d+$/,""))+":"+e.serverConnection.remote_address().port+"/?forward_url="+encodeURIComponent(c)'
if cert_url_old_snippet not in connection_bundle_js:
    raise SystemExit("missing TeaWeb certificate callback URL patch target")
connection_bundle_js = connection_bundle_js.replace(cert_url_old_snippet, cert_url_new_snippet, 1)

connection_bundle_path.write_text(connection_bundle_js, encoding="utf-8")
PY

RUN rm /var/www/TeaWeb/TeaWeb-release.zip

ENV TEAWEB_VERSION="${TEAWEB_VERSION}"

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]